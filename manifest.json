{
  "name": "brain3d",
  "version": "3.1.19",
  "core": {
    "name": "brain3d",
    "type": "python",
    "display_name": "Brain3D Visualizer",
    "description": "Visualisation 3D temps réel du réseau Onyx avec Infrastructure Registry",
    "long_description": "Interface de monitoring 3D interactive avec layout force-directed. Communication temps réel via Redis Message Bus.",
    "version": "3.1.0",
    "author": "Onyx",
    "brain_area": "cerebellum",
    "category": "monitoring",
    "tags": [
      "monitoring",
      "3d",
      "visualization",
      "websocket",
      "real-time",
      "redis"
    ],
    "icon": "🧠",
    "critical": true,
    "priority": 1,
    "routing": {
      "host": "10.0.0.44",
      "port": 8888,
      "protocol": "http"
    },
    "health_endpoint": "/health"
  },
  "heart": {
    "deployment": {
      "target_host": "10.0.0.44",
      "platform": "linux",
      "mode": "direct",
      "auto_start": true,
      "restart_policy": "always"
    },
    "lifecycle": {
      "start_command": "python -m src.main",
      "health_check_url": "http://10.0.0.44:8888/health",
      "health_check_interval": 30,
      "startup_timeout": 30
    }
  },
  "forge": {
    "type": "python",
    "repository": "VersoVet/brain3d",
    "development": {
      "progress_percent": 100,
      "dev_status": "deployed",
      "dev_platform": "dendrite",
      "test_platform": "dendrite"
    },
    "python": {
      "src_dir": ".",
      "entry_point": "src/main.py",
      "min_version": "3.10"
    },
    "server": {
      "enabled": true,
      "protocol": "fastapi",
      "port": 8888
    },
    "dashboard": {
      "enabled": true,
      "page": "/",
      "category": "monitoring",
      "title": "Brain3D Visualizer"
    }
  },
  "integration": {
    "redis": {
      "enabled": true,
      "subscribe_channels": [
        "onyx:events",
        "onyx:skill:status"
      ]
    },
    "onyx_core": {
      "enabled": true,
      "url": "http://10.0.0.44:8050"
    },
    "onyx_infra": {
      "enabled": true,
      "url": "http://10.0.0.44:8053"
    }
  },
  "endpoints": [
    {
      "method": "GET",
      "path": "/",
      "description": "Page principale Brain3D"
    },
    {
      "method": "GET",
      "path": "/health",
      "description": "Health check endpoint"
    },
    {
      "method": "GET",
      "path": "/status",
      "description": "Detailed status (Redis, WebSocket clients)"
    },
    {
      "method": "GET",
      "path": "/api/state",
      "description": "Complete network state"
    },
    {
      "method": "GET",
      "path": "/api/machines",
      "description": "List of all machines"
    },
    {
      "method": "GET",
      "path": "/api/skills",
      "description": "List of all skills"
    },
    {
      "method": "GET",
      "path": "/api/areas",
      "description": "List of brain areas"
    },
    {
      "method": "POST",
      "path": "/api/metrics/{node_id}",
      "description": "Receive and process metrics for a machine"
    },
    {
      "method": "POST",
      "path": "/api/refresh",
      "description": "Force state refresh"
    },
    {
      "method": "WS",
      "path": "/ws",
      "description": "WebSocket real-time updates"
    }
  ]
}