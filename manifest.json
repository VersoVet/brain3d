{
  "name": "brain3d",
  "display_name": "Brain3D Visualizer",
  "version": "3.1.0",
  "description": "Visualisation 3D temps reel du reseau Onyx avec Infrastructure Registry",
  "long_description": "Interface de monitoring 3D interactive avec layout force-directed. Communication temps reel via Redis Message Bus. Vues: reseau global (machines), vue interne (Core/Heart/Aires/Skills). Heritage des statuts avec propagation automatique.",
  "category": "monitoring",
  "brain_area": "cortex-prefrontal",
  "author": "Onyx",
  "icon": "\ud83e\udde0",
  "color": "#00d4aa",
  "port": 8888,
  "dev_port": 9888,
  "protocol": "http",
  "has_web_ui": true,
  "web_url": "http://10.0.0.44:8888",
  "health_endpoint": "/health",
  "critical": true,
  "priority": 1,

  "endpoints": [
    {
      "method": "GET",
      "path": "/",
      "description": "Page principale Brain3D"
    },
    {
      "method": "GET",
      "path": "/health",
      "description": "Health check"
    },
    {
      "method": "GET",
      "path": "/status",
      "description": "Statut detaille (Redis, WS clients)"
    },
    {
      "method": "GET",
      "path": "/api/state",
      "description": "Etat complet du reseau"
    },
    {
      "method": "GET",
      "path": "/api/machines",
      "description": "Liste des machines"
    },
    {
      "method": "GET",
      "path": "/api/machines/{node_id}",
      "description": "Detail d'une machine"
    },
    {
      "method": "GET",
      "path": "/api/skills",
      "description": "Liste des skills"
    },
    {
      "method": "GET",
      "path": "/api/skills/{name}",
      "description": "Detail d'un skill"
    },
    {
      "method": "GET",
      "path": "/api/areas",
      "description": "Liste des aires cerebrales"
    },
    {
      "method": "GET",
      "path": "/api/areas/{area_id}",
      "description": "Detail d'une aire"
    },
    {
      "method": "POST",
      "path": "/api/refresh",
      "description": "Force refresh de l'etat"
    },
    {
      "method": "WS",
      "path": "/ws",
      "description": "WebSocket temps reel"
    }
  ],

  "dependencies": [],

  "tags": [
    "monitoring",
    "3d",
    "visualization",
    "websocket",
    "real-time",
    "redis",
    "force-directed"
  ],

  "deployment": {
    "host": "10.0.0.44",
    "host_name": "OnyxSoma",
    "port": 8888,
    "protocol": "http",
    "mode": "direct",
    "auto_start": true,
    "restart_policy": "always"
  },

  "development": {
    "dev_platform": "onyxlab",
    "dev_path": "/home/onyx/projects/skills",
    "test_platform": "onyxlab",
    "remote_mount": false
  },

  "requirements": {
    "python": ">=3.10",
    "min_ram_mb": 256,
    "min_disk_mb": 100,
    "packages": [
      "fastapi>=0.109.0",
      "uvicorn[standard]>=0.27.0",
      "redis>=5.0.0",
      "httpx>=0.25.0",
      "pydantic>=2.0.0",
      "jinja2>=3.0.0",
      "websockets>=12.0"
    ]
  },

  "brain3d": {
    "visible": false,
    "reason": "Brain3D est le visualiseur, il ne se visualise pas lui-meme"
  },

  "integration": {
    "onyxheart": true,
    "onyxcore": true,
    "redis": true,
    "events_subscribed": ["onyx:events"],
    "events_published": []
  },

  "dashboard": {
    "enabled": true,
    "path": "/",
    "title": "Brain3D Visualizer"
  },

  "forge": {
    "development": {
      "progress_percent": 65,
      "dev_status": "in_progress",
      "last_update": "2026-01-01"
    }
  }
}
